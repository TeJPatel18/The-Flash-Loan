# Polygon RPC URL
POLYGON_RPC_URL=https://polygon-rpc.com/

# Wallet private key (keep this secret!)
PRIVATE_KEY=your_private_key_here

# Contract address (deployed LiquidationBot)
LIQUIDATION_BOT_ADDRESS=your_liquidation_bot_contract_address_here

# The Graph API key for borrower discovery
GRAPH_API_KEY=your_graph_api_key_here

# Optional scan controls
BORROWER_FETCH_LIMIT=500
SCAN_INTERVAL_SECONDS=30
UNPROFITABLE_COOLDOWN_SECONDS=900
MIN_DEBT_TO_COVER_USD=10
MIN_NET_PROFIT_USD=0.25
DEBT_TOKENS=USDCe,USDC,USDT,DAI
COLLATERAL_TOKENS=WBTC,WETH,WMATIC,AAVE,LINK,DAI,USDCe,USDC,USDT
